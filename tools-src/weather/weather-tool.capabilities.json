{
    "version": "0.1.0",
    "wit_version": "0.3.0",
    "description": "Get weather information using Open-Meteo (no API key required). Supports three actions: get_current for current weather, get_forecast for a 5-day forecast, and get_air_quality for pollution data by coordinates.",
    "capabilities": {
        "http": {
            "allowlist": [
                {
                    "host": "geocoding-api.open-meteo.com",
                    "path_prefix": "/v1/",
                    "methods": [
                        "GET"
                    ]
                },
                {
                    "host": "api.open-meteo.com",
                    "path_prefix": "/v1/",
                    "methods": [
                        "GET"
                    ]
                },
                {
                    "host": "air-quality-api.open-meteo.com",
                    "path_prefix": "/v1/",
                    "methods": [
                        "GET"
                    ]
                }
            ],
            "rate_limit": {
                "requests_per_minute": 60,
                "requests_per_hour": 500
            },
            "timeout_secs": 15
        }
    }
}