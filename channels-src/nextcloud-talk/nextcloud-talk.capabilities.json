{
  "version": "0.1.0",
  "wit_version": "0.3.0",
  "type": "channel",
  "name": "nextcloud-talk",
  "description": "Nextcloud Talk webhook channel using fake-user credentials configured in the extension UI",
  "auth": {
    "secret_name": "nextcloud_talk_base_url",
    "display_name": "Nextcloud Talk",
    "instructions": "Configure Nextcloud base URL, fake-user ID (login username), fake-user display name, app password, and optional webhook signature secret in the IronClaw extension setup UI.",
    "setup_url": "https://nextcloud.com/talk/",
    "token_hint": "Configure all Nextcloud channel credentials in the IronClaw extension setup UI"
  },
  "setup": {
    "required_secrets": [
      {
        "name": "nextcloud_talk_base_url",
        "prompt": "Nextcloud base URL (example: https://cloud.example.tld)",
        "optional": false
      },
      {
        "name": "nextcloud_talk_bot_username",
        "prompt": "Nextcloud fake-user ID (login username, e.g. ki_assistent)",
        "optional": false
      },
      {
        "name": "nextcloud_talk_app_password",
        "prompt": "Nextcloud app password for fake-user",
        "optional": false
      },
      {
        "name": "nextcloud_talk_webhook_secret",
        "prompt": "Optional webhook signature secret for X-Nextcloud-Talk-Signature verification",
        "optional": true
      },
      {
        "name": "nextcloud_talk_bot_display_name",
        "prompt": "Fake-user display name used for mention matching (e.g. KI Gerda)",
        "optional": true
      }
    ],
    "secret_config_mappings": [
      {
        "config_key": "base_url",
        "secret_name": "nextcloud_talk_base_url"
      },
      {
        "config_key": "bot_username",
        "secret_name": "nextcloud_talk_bot_username"
      },
      {
        "config_key": "app_password",
        "secret_name": "nextcloud_talk_app_password"
      },
      {
        "config_key": "webhook_secret",
        "secret_name": "nextcloud_talk_webhook_secret"
      },
      {
        "config_key": "bot_display_name",
        "secret_name": "nextcloud_talk_bot_display_name"
      }
    ],
    "setup_url": "https://nextcloud.com/talk/"
  },
  "capabilities": {
    "http": {
      "allowlist": [
        {
          "host": "next.cloud.kiga-gramschatz.de",
          "path_prefix": "/ocs/v2.php/apps/spreed/api/v1/chat/"
        }
      ],
      "rate_limit": {
        "requests_per_minute": 60,
        "requests_per_hour": 1000
      }
    },
    "secrets": {
      "allowed_names": [
        "nextcloud_talk_*"
      ]
    },
    "channel": {
      "allowed_paths": [
        "/webhooks/nextcloud/talk"
      ],
      "allow_polling": false,
      "workspace_prefix": "channels/nextcloud-talk/",
      "emit_rate_limit": {
        "messages_per_minute": 100,
        "messages_per_hour": 5000
      },
      "webhook": {
        "secret_header": "X-Nextcloud-Talk-Signature",
        "secret_name": "nextcloud_talk_webhook_secret",
        "managed_by_host": false
      }
    }
  },
  "config": {
    "base_url": null,
    "bot_username": null,
    "app_password": null,
    "webhook_secret": null,
    "bot_display_name": "ironclaw",
    "require_mention": true,
    "mention_mode": "exact"
  }
}